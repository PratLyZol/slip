# Slip environment.
# With NONE of these set, the app runs fully in deterministic demo mode.

# Dynamic environment id (public). Get one at https://app.dynamic.xyz.
# When present, the real Dynamic wallet provider mounts and demo mode turns off
# (unless NEXT_PUBLIC_DEMO_MODE=true is also set).
NEXT_PUBLIC_DYNAMIC_ENV_ID=

# Dynamic server API token (SERVER-ONLY — never bundled to the client). The
# `dyn_…` token from dashboard → Developer → API Token. Enables the real pregen
# route (waas/create) + wallet lookups. Without it, pregen returns a demo address.
DYNAMIC_API_TOKEN=

# Unlink admin API key (SERVER-ONLY — never bundled to the client). Self-serve at
# https://dashboard.unlink.xyz (project → Arc testnet). Enables the real Unlink
# shielded path; without it, the privacy legs are simulated deterministically.
UNLINK_API_KEY=

# Unlink app id (public tenant label). Defaults to "slip" when unset.
NEXT_PUBLIC_UNLINK_APP_ID=slip

# CCTP source funds (SERVER-ONLY — never bundled to the client). Private key of a
# funded Base Sepolia EOA (Base Sepolia ETH + USDC from https://faucet.circle.com).
# Signs the CCTP burn that bridges Σ to Arc; absent, the bridge is simulated.
CCTP_PRIVATE_KEY=

# Circle StableFX key (SERVER-ONLY — never bundled to the client). Format
# PREFIX:ID:SECRET. Contact-a-rep at sales@circle.com — request Day 0. Primary real
# FX (USDC→EURC); absent, FX cascades to Swap Kit then the deterministic sim.
STABLEFX_API_KEY=

# Circle Kit key (SERVER-ONLY — never bundled to the client). Self-serve at
# https://console.circle.com → Keys → Kit Key. Powers the Swap Kit fallback FX
# (real on-chain USDC→EURC); absent, FX falls back to the sim.
CIRCLE_KIT_KEY=

# Optional Base Sepolia RPC override (SERVER-ONLY). Falls back to the SDK default.
BASE_SEPOLIA_RPC_URL=

# Force demo mode even when other keys are present (great for the live demo).
NEXT_PUBLIC_DEMO_MODE=true
